<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginTop="8dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Movie Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Movie Poster -->
            <ImageView
                android:id="@+id/image_poster"
                android:layout_width="120dp"
                android:layout_height="160dp"
                android:scaleType="centerCrop"
                tools:src="@drawable/placeholder_image" />

            <!-- Movie Info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Movie Title -->
                <TextView
                    android:id="@+id/text_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#333333"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    tools:text="Lật Mặt 8: Vòng Tay Nắng" />

                <!-- Movie Info (Genre, Duration, etc.) -->
                <TextView
                    android:id="@+id/text_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#666666"
                    android:textSize="14sp"
                    tools:text="Nhạc, Chính Kịch, Gia Đình | 2D, Dolby Atmos | 123 phút" />

                <!-- Detail Button -->
                <Button
                    android:id="@+id/button_detail"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="#E91E63"
                    android:text="Chi tiết"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <!-- Trailer Button -->
                <Button
                    android:id="@+id/button_trailer"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:drawableStart="@drawable/ic_play"
                    android:text="Trailer"
                    android:textColor="#E91E63"
                    android:textSize="12sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Showtimes Grid -->
        <GridLayout
            android:id="@+id/container_showtimes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:columnCount="2">
            <!-- Showtimes will be added here dynamically -->
        </GridLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
